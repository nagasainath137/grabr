# ─── Backend .env ─────────────────────────────────────────────────────────
# Copy this to backend/.env and fill in values

# Port for the Express server (default: 3001)
PORT=3001

# Path to yt-dlp binary (default: "yt-dlp" — assumes it's in PATH)
# On Windows: YT_DLP_PATH=C:\Users\you\AppData\Local\Programs\Python\Scripts\yt-dlp.exe
# On Mac/Linux: YT_DLP_PATH=/usr/local/bin/yt-dlp
YT_DLP_PATH=yt-dlp

# Allowed frontend origin for CORS (use * for all during dev)
FRONTEND_URL=http://localhost:5173

# Node environment
NODE_ENV=development

# ─── Frontend .env ─────────────────────────────────────────────────────────
# Copy relevant vars to frontend/.env

# Backend API URL (leave blank to use Vite proxy in dev, set for production)
VITE_API_URL=http://localhost:3001
